# =====================================================================
# El Castillo Barracas - variables de entorno para Docker Compose
# Copiar a `.env` y completar antes de correr `docker compose up -d`.
# El archivo `.env` NO debe commitearse (ya esta en .gitignore).
# =====================================================================

# ---------------------------------------------------------------------
# Puertos publicados al host (VPS)
# ---------------------------------------------------------------------
# Puerto en el que escucha el frontend (nginx) en el VPS.
# Si usas un reverse proxy externo (Traefik, nginx del host, etc), poné un
# puerto interno como 8080 y proxeá vos. Si no, dejá 80 para servir directo.
FRONTEND_PORT=80

# Puerto interno del backend (no se publica salvo que descomentes en compose).
BACKEND_PORT=3000

# Puerto de Postgres en el host (solo si descomentas el publish en compose).
POSTGRES_PORT=5432

# ---------------------------------------------------------------------
# Base de datos (Postgres)
# ---------------------------------------------------------------------
POSTGRES_DB=el_castillo
POSTGRES_USER=el_castillo
POSTGRES_PASSWORD=cambiame_en_produccion

# TypeORM synchronize: en prod conviene 'false' y usar migrations.
TYPEORM_SYNCHRONIZE=true

# ---------------------------------------------------------------------
# URLs publicas
# ---------------------------------------------------------------------
# Dominio publico del frontend (lo que ve el navegador del usuario).
FRONTEND_URL=https://entradas.ecbamerica.com

# URL publica del backend. Si servís el back atras de /api en el mismo
# dominio (recomendado), dejalo asi:
BACKEND_URL=https://entradas.ecbamerica.com/api
BASE_PUBLIC_URL=https://entradas.ecbamerica.com/api

# URL que usa el frontend (Vite) para llamar al API. En build time.
# Si el front y el back salen por el mismo dominio, usar "/api" relativo.
VITE_API_URL=/api

# ---------------------------------------------------------------------
# Auth / JWT
# ---------------------------------------------------------------------
JWT_SECRET=cambiame_por_un_secreto_largo_y_random
JWT_EXPIRES_IN=3600s

# ---------------------------------------------------------------------
# Google OAuth
# ---------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://entradas.ecbamerica.com/api/auth/google/callback

# ---------------------------------------------------------------------
# Mailer (SMTP)
# ---------------------------------------------------------------------
MAILER_HOST=smtp.gmail.com
MAILER_PORT=587
MAILER_USER=
MAILER_PASS=

# ---------------------------------------------------------------------
# Mercado Pago
# ---------------------------------------------------------------------
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# ---------------------------------------------------------------------
# WhatsApp Business API
# ---------------------------------------------------------------------
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
