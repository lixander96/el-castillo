# =====================================================================
# El Castillo Barracas - variables de entorno para Docker Compose
# Copiar a `.env` y completar antes de correr `docker compose up -d`.
# El archivo `.env` NO debe commitearse (ya esta en .gitignore).
# =====================================================================

# ---------------------------------------------------------------------
# Identidad del proyecto / Traefik
# ---------------------------------------------------------------------
# Nombre del stack. Define el prefijo de los contenedores, la red interna
# (<nombre>-net) y los nombres de los routers de Traefik. Unico por cliente.
COMPOSE_PROJECT_NAME=el-castillo

# Dominio publico del FRONTEND (lo que ve el navegador). La API se publica
# automaticamente en el subdominio api.<TRAEFIK_HOST>.
#   frontend -> https://${TRAEFIK_HOST}
#   backend  -> https://api.${TRAEFIK_HOST}
TRAEFIK_HOST=entradas.ecbamerica.com

# ---------------------------------------------------------------------
# Base de datos (Postgres)
# ---------------------------------------------------------------------
POSTGRES_DB=ticket_system
POSTGRES_USER=ticket_system
# OBLIGATORIO: completar por cada instalacion (Postgres no arranca vacio).
POSTGRES_PASSWORD=

# TypeORM synchronize: en prod conviene 'false' y usar migrations.
TYPEORM_SYNCHRONIZE=true

# ---------------------------------------------------------------------
# URLs publicas
# ---------------------------------------------------------------------
# IMPORTANTE: con Traefik el backend vive en su propio subdominio (api.*),
# por eso las rutas NO llevan prefijo /api (eso era del proxy nginx).
FRONTEND_URL=https://entradas.ecbamerica.com
BACKEND_URL=https://api.entradas.ecbamerica.com
BASE_PUBLIC_URL=https://api.entradas.ecbamerica.com

# URL que usa el frontend (Vite) para llamar al API. Se hornea en build time.
# Con Traefik + subdominio de API:
VITE_API_URL=https://api.entradas.ecbamerica.com
# Alternativa path-based (frontend y back en el mismo dominio via nginx,
# util en LOCAL con docker-compose.local.yml): VITE_API_URL=/api

# ---------------------------------------------------------------------
# Puertos (solo para desarrollo local con docker-compose.local.yml)
# ---------------------------------------------------------------------
# En produccion con Traefik no se publica ningun puerto al host.
FRONTEND_PORT=80
BACKEND_PORT=3000
POSTGRES_PORT=5432

# ---------------------------------------------------------------------
# Auth / JWT
# ---------------------------------------------------------------------
JWT_SECRET=cambiame_por_un_secreto_largo_y_random
JWT_EXPIRES_IN=3600s

# ---------------------------------------------------------------------
# Google OAuth
# ---------------------------------------------------------------------
# El callback debe coincidir EXACTO con lo cargado en Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.entradas.ecbamerica.com/auth/google/callback

# ---------------------------------------------------------------------
# Mailer (SMTP)
# ---------------------------------------------------------------------
MAILER_HOST=smtp.gmail.com
MAILER_PORT=587
MAILER_USER=
MAILER_PASS=

# ---------------------------------------------------------------------
# Mercado Pago (App OAuth global de la plataforma)
# ---------------------------------------------------------------------
# Estas credenciales pertenecen a TU app de Mercado Pago Developers y se
# comparten entre todos los deployments que clones para clientes. El cliente
# nunca las ve ni las edita: solo clickea "Conectar" en /configuracion.
#
# 1) Crear UNA sola app en https://www.mercadopago.com.ar/developers/panel/app
# 2) En "URIs de redireccion" registrar la URL de cada deployment:
#      ${BACKEND_URL}/payments/mp/oauth/callback
#    (ej: https://api.entradas.ecbamerica.com/payments/mp/oauth/callback)
# 3) Copiar Client ID y Secret aca.
MP_OAUTH_CLIENT_ID=
MP_OAUTH_CLIENT_SECRET=
# Si necesitas overridear la URL de callback derivada de BACKEND_URL:
# MP_OAUTH_REDIRECT_URI=https://api.entradas.ecbamerica.com/payments/mp/oauth/callback

# ---------------------------------------------------------------------
# WhatsApp Business API
# ---------------------------------------------------------------------
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
