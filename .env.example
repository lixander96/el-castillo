# =====================================================================
# Plataforma de tickets - variables de entorno para Docker Compose
# Copiar a `.env` y completar antes de correr `docker compose up -d`.
# El archivo `.env` NO debe commitearse (ya esta en .gitignore).
#
# Arquitectura: UN solo contenedor de app (NestJS) sirve la SPA + la API
# (/api) + los uploads (/api/uploads), todo en un unico dominio detras de
# Traefik. No hay nginx ni subdominio api.*.
# =====================================================================

# ---------------------------------------------------------------------
# Identidad del proyecto / Traefik
# ---------------------------------------------------------------------
# Nombre del stack. Define el prefijo de los contenedores, la red interna

# (<nombre>-net) y los nombres de los routers de Traefik. Unico por cliente.
# En Docker Manager ya viene configurado solo esta variable
# COMPOSE_PROJECT_NAME=

# Dominio publico (lo que ve el navegador). Todo sale por aca.
TRAEFIK_HOST=tudominio.com

# ---------------------------------------------------------------------
# Base de datos (Postgres)
# ---------------------------------------------------------------------
POSTGRES_DB=ticket_system
POSTGRES_USER=ticket_system
# OBLIGATORIO: completar por cada instalacion (Postgres no arranca vacio).
POSTGRES_PASSWORD=

# TypeORM synchronize: en prod conviene 'false' y usar migrations.
TYPEORM_SYNCHRONIZE=true

# ---------------------------------------------------------------------
# URLs publicas (un solo dominio; la API vive bajo /api)
# ---------------------------------------------------------------------
FRONTEND_URL=https://tudominio.com
BACKEND_URL=https://tudominio.com/api
BASE_PUBLIC_URL=https://tudominio.com/api

# Puerto al host (SOLO para docker-compose.local.yml; en prod manda Traefik).
APP_PORT=3000
# POSTGRES_PORT=5432

# ---------------------------------------------------------------------
# Auth / JWT
# ---------------------------------------------------------------------
# OBLIGATORIO: secreto largo y random (no usar el del ejemplo en prod).
JWT_SECRET=
JWT_EXPIRES_IN=3600s

# ---------------------------------------------------------------------
# Google OAuth
# ---------------------------------------------------------------------
# El callback debe coincidir EXACTO con lo cargado en Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://tudominio.com/api/auth/google/callback

# ---------------------------------------------------------------------
# Mailer (SMTP)
# ---------------------------------------------------------------------
MAILER_HOST=smtp.gmail.com
MAILER_PORT=587
MAILER_USER=
MAILER_PASS=

# ---------------------------------------------------------------------
# Mercado Pago (App OAuth global de la plataforma)
# ---------------------------------------------------------------------
# Una sola app de MP Developers, compartida entre todos los deployments.
# En "URIs de redireccion" registrar, por cada deployment:
#   ${BACKEND_URL}/payments/mp/oauth/callback
#   (ej: https://tudominio.com/api/payments/mp/oauth/callback)
MP_OAUTH_CLIENT_ID=
MP_OAUTH_CLIENT_SECRET=
# Si necesitas overridear la URL de callback derivada de BACKEND_URL:
# MP_OAUTH_REDIRECT_URI=https://tudominio.com/api/payments/mp/oauth/callback

# ---------------------------------------------------------------------
# WhatsApp Business API
# ---------------------------------------------------------------------
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
